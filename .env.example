# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database: any PostgreSQL provider works. Local Docker default is shown here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/umkmcepat?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="umkmcepat"

# Auth / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-local-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudflare Turnstile. Leave empty in local development to use the dev check.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Optional: Chromatic visual tests for Storybook publishing and visual baselines.
CHROMATIC_PROJECT_TOKEN=""

# Optional: raises GitHub API rate limit for the public contributors strip.
GITHUB_TOKEN=""

# AI provider. Preferred runtime: 9Router proxy (OpenAI-compatible).
AI_PROVIDER="9router"
# Comma-separated. First model is the default.
AI_MODELS="cmc/zai-org/GLM-5.2,cmc/deepseek/deepseek-v4-pro,cmc/deepseek/deepseek-v4-flash,cmc/moonshotai/Kimi-K2.6"
NINE_ROUTER_BASE_URL="http://localhost:20129/v1"
NINE_ROUTER_API_KEY=""

# Object storage. Default local saves uploads under .data/uploads.
# For production Docker/local VPS, mount this folder as a persistent volume.
# R2 env is reserved for the Cloudflare R2 adapter; keep provider local for now.
OBJECT_STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR=".data/uploads"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Rate limit provider: memory or none.
RATE_LIMIT_PROVIDER="memory"
RATE_LIMIT_GLOBAL_IP_REQUESTS="300"
RATE_LIMIT_GLOBAL_IP_WINDOW_SECONDS="60"
RATE_LIMIT_AI_USER_REQUESTS="60"
RATE_LIMIT_AI_USER_WINDOW_SECONDS="600"
RATE_LIMIT_AI_IP_REQUESTS="20"
RATE_LIMIT_AI_IP_WINDOW_SECONDS="600"
RATE_LIMIT_BUILD_USER_REQUESTS="10"
RATE_LIMIT_BUILD_USER_WINDOW_SECONDS="3600"
RATE_LIMIT_BUILD_IP_REQUESTS="5"
RATE_LIMIT_BUILD_IP_WINDOW_SECONDS="3600"

# Generated project local runtime/build cache. These are rebuildable local artifacts.
PROJECT_ARTIFACT_DIR=".data/project-artifacts"
PROJECT_RUNTIME_DIR=".data/project-runtimes"
PROJECT_BUILD_WORKSPACE_DIR=".data/project-build-workspaces"
PROJECT_RUNTIME_SUPERVISOR="local"
PROJECT_RUNTIME_MAX_CONTAINERS="8"
PROJECT_BUILD_CONCURRENCY="1"

# Optional Sentry monitoring. Leave empty for local development.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
