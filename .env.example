# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database: any PostgreSQL provider works. Local Docker default is shown here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/umkmcepat?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="umkmcepat"

# Auth / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-local-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudflare Turnstile. Leave empty in local development to use the dev check.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Pilot waitlist admin allowlist. Comma-separated admin emails that may approve
# waitlist entries (no Role model). Leave empty locally (the dev-bypass lets
# signed-in users without an entry through in non-production).
ADMIN_EMAILS=""

# Optional: Chromatic visual tests for Storybook publishing and visual baselines.
CHROMATIC_PROJECT_TOKEN=""

# Optional: raises GitHub API rate limit for the public contributors strip.
GITHUB_TOKEN=""

# AI provider. Preferred runtime: 9Router proxy (OpenAI-compatible).
# 9Router combo handles model fallback. Set AI_MODELS to a combo id (combo/<name>).
AI_PROVIDER="9router"
AI_MODELS="umkmcepat-combo"
AI_TIMEOUT_MODERATION_MS="30000"
AI_TIMEOUT_DISCUSS_MS="90000"
AI_TIMEOUT_DISCUSS_TOOL_SETTLE_MS="30000"
AI_TIMEOUT_CHAT_COMPACTION_MS="60000"
AI_TIMEOUT_BUILD_SPEC_MS="120000"
AI_TIMEOUT_SOURCE_GENERATION_MS="600000"
AI_TIMEOUT_EDIT_MS="600000"
AI_TIMEOUT_EDIT_REPAIR_MS="300000"

# Agent tool-loop step budgets (brake only; outcome is quality checklist).
AI_AGENT_GENERATE_MAX_STEPS="12"
AI_AGENT_REPAIR_MAX_STEPS="12"
# Read-only sub-agent step budget (spawn_subagent research fan-out).
AI_AGENT_SUBAGENT_MAX_STEPS="8"

NINE_ROUTER_BASE_URL="http://localhost:20129/v1"
NINE_ROUTER_API_KEY=""

# Object storage. Default local saves uploads under .data/uploads.
# For production Docker/local VPS, mount this folder as a persistent volume.
# R2 env is reserved for the Cloudflare R2 adapter; keep provider local for now.
OBJECT_STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR=".data/uploads"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Rate limit provider: memory or none.
RATE_LIMIT_PROVIDER="memory"
RATE_LIMIT_GLOBAL_IP_REQUESTS="300"
RATE_LIMIT_GLOBAL_IP_WINDOW_SECONDS="60"
RATE_LIMIT_AI_USER_REQUESTS="60"
RATE_LIMIT_AI_USER_WINDOW_SECONDS="600"
RATE_LIMIT_AI_IP_REQUESTS="20"
RATE_LIMIT_AI_IP_WINDOW_SECONDS="600"
RATE_LIMIT_BUILD_USER_REQUESTS="10"
RATE_LIMIT_BUILD_USER_WINDOW_SECONDS="3600"
RATE_LIMIT_BUILD_IP_REQUESTS="5"
RATE_LIMIT_BUILD_IP_WINDOW_SECONDS="3600"

# Max projects per user before a soft warning is shown. Default 5.
PROJECT_LIMIT="3"

# Generated app execution safety. Local/test defaults are enabled when omitted.
# Production Compose hardcodes both switches off and runtime authority to noop until external gates pass.
GENERATED_BUILD_EXECUTION_ENABLED="true"
GENERATED_PUBLIC_EXECUTION_ENABLED="true"
GENERATED_PUBLIC_ORIGIN=""
# Discuss: 1-call stream text + presentWorkspaceCard tool (faster). Defaults on in dev, off in prod.
DISCUSS_ONE_CALL_TOOLS="true"

# Canonical generated source/dist storage. The local path is for development;
# production Compose fixes it to its mounted /app/.data/project-artifacts volume.
PROJECT_ARTIFACT_STORAGE_PROVIDER="local"
PROJECT_ARTIFACT_DIR=".data/project-artifacts"
# Owner-uploaded project assets (business images / references / logos) for the
# builder + waitlist evidence flow. Prod Compose mounts /app/.data/project-assets.
PROJECT_ASSET_DIR=".data/project-assets"
PROJECT_THUMBNAIL_DIR=".data/project-thumbnails"
PROJECT_THUMBNAIL_CAPTURE_ENABLED="true"
PROJECT_THUMBNAIL_BROWSER_PATH=""
# Node runs the isolated screenshot process. Leave empty to use `node` on PATH.
PROJECT_THUMBNAIL_NODE_PATH=""
PROJECT_THUMBNAIL_CONCURRENCY="1"
PROJECT_THUMBNAIL_TIMEOUT_MS="15000"
PROJECT_ARTIFACT_R2_PREFIX="project-artifacts"
PROJECT_SOURCE_MAX_FILES="100"
PROJECT_SOURCE_MAX_FILE_BYTES="262144"
PROJECT_SOURCE_MAX_TOTAL_BYTES="5242880"
PROJECT_DIST_MAX_FILES="500"
PROJECT_DIST_MAX_FILE_BYTES="10485760"
PROJECT_DIST_MAX_TOTAL_BYTES="52428800"
# Runtime/build workspaces below are rebuildable and are not canonical artifacts.
PROJECT_RUNTIME_DIR=".data/project-runtimes"
PROJECT_BUILD_WORKSPACE_DIR=".data/project-build-workspaces"
PROJECT_RUNTIME_SUPERVISOR="local"
PROJECT_RUNTIME_MAX_CONTAINERS="8"
PROJECT_RUNTIME_ALLOWED_HOSTS="127.0.0.1,localhost"
PROJECT_RUNTIME_HEALTH_TIMEOUT_MS="2000"
PROJECT_RUNTIME_PROXY_TIMEOUT_MS="15000"
PREVIEW_ASSET_TOKEN_TTL_SECONDS="300"
# Optional comma-separated rotation set. First secret signs; all entries verify.
# Leave empty to use NEXTAUTH_SECRET/AUTH_SECRET.
PREVIEW_ASSET_TOKEN_SECRETS=""
PROJECT_BUILD_CONCURRENCY="1"

# Optional Sentry monitoring. Leave empty for local development.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# WhatsApp OTP verification (OTP Space). Register at https://otpspace.com
# Leave empty to use mock mode (logs OTP to console).
OTP_SPACE_API_KEY=""

# Pakasir Payment Integration
PAKASIR_API_KEY="xxx"
PAKASIR_PROJECT_SLUG="xxx"
# Agent web search. "none" disables the web_search tool (default — local/no-key).
# "firecrawl" activates it against a self-hosted Firecrawl.
#
# LOCAL DEV (host `bun dev`): point at the host port of your running Firecrawl:
#   FIRECRAWL_BASE_URL="http://localhost:3002"   # your real Firecrawl API port
# (If you don't run Firecrawl yet: `docker compose --profile firecrawl up -d`
#  brings up a throwaway stack on host port 38383 -> set the URL to http://localhost:38383)
#
# PRODUCTION (app inside a container): the prod compose joins the external
# `firecrawl_backend` network, so use the Docker DNS name, NOT localhost
# (localhost inside a container is the app itself):
#   FIRECRAWL_BASE_URL="http://firecrawl-api-1:3002"
# Your self-hosted Firecrawl needs no API key (beta auth); leave FIRECRAWL_API_KEY empty.
WEBSEARCH_PROVIDER="none"
FIRECRAWL_BASE_URL=""
FIRECRAWL_API_KEY=""
# Comma-separated host allowlist (deny-by-default). Empty = curated Indonesian-business seed.
WEBSEARCH_ALLOWLIST=""
WEBSEARCH_DENYLIST=""
