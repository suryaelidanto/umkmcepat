# Copy to .env for local development. Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database: any PostgreSQL provider works. Local Docker default is shown here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/umkmcepat?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="umkmcepat"

# Auth / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-local-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI provider. Preferred runtime: 9Router proxy (OpenAI-compatible).
AI_PROVIDER="9router"
AI_MODEL="cmc/deepseek/deepseek-v4-pro"
NINE_ROUTER_BASE_URL="http://localhost:20129/v1"
NINE_ROUTER_API_KEY=""
NINE_ROUTER_MODEL="cmc/deepseek/deepseek-v4-pro"

# Object storage provider: local, r2, s3, or minio.
# r2/s3/minio use the S3-compatible variables below.
STORAGE_PROVIDER="local"
UPLOAD_DIR="public/uploads"
PUBLIC_UPLOAD_BASE_URL="/uploads"
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""
S3_FORCE_PATH_STYLE="false"

# Rate limit provider: memory or none.
RATE_LIMIT_PROVIDER="memory"

# Queue provider. No runtime queue is currently implemented.
QUEUE_PROVIDER="none"

# Optional Sentry monitoring. Leave empty for local development.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
