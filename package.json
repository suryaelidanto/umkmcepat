{
  "name": "umkmcepat",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev -p 3000",
    "start": "next start",
    "build": "next build",
    "check": "bun run check:locks && bun run format && bun run lint && bun run typecheck && bun run test && bun run knip",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .prettierignore",
    "lint": "eslint . --max-warnings=0",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "check:locks": "bun -e \"import { existsSync } from 'node:fs'; const bad = ['package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'bun.lockb'].filter(existsSync); if (!existsSync('bun.lock') || bad.length) { console.error('Use Bun only. Lockfile: bun.lock. Remove: ' + (bad.join(', ') || 'missing bun.lock')); process.exit(1); }\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1071.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-accordion": "^1.2.7",
    "@radix-ui/react-alert-dialog": "^1.1.10",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.7.4",
    "lucide-react": "^0.503.0",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.26",
    "next-themes": "^0.4.6",
    "openai": "^4.95.1",
    "prisma": "^6.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "yet-another-react-lightbox": "^3.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3",
    "@sentry/nextjs": "^10.58.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": "1.3.9"
  },
  "packageManager": "bun@1.3.9"
}
