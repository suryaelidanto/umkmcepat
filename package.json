{
  "name": "umkmcepat",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "bun run check:locks && bun run check:fast",
    "check:commit": "bun run check:locks && bun scripts/check-staged.ts",
    "check:fast": "bun run check:parallel",
    "check:locks": "bun -e \"import { existsSync } from 'node:fs'; const bad = ['package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'bun.lockb'].filter(existsSync); if (!existsSync('bun.lock') || bad.length) { console.error('Use Bun only. Lockfile: bun.lock. Remove: ' + (bad.join(', ') || 'missing bun.lock')); process.exit(1); }\"",
    "check:parallel": "bun scripts/check-parallel.ts",
    "chromatic": "chromatic",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d postgres",
    "dev": "vite dev --port 3000",
    "dev:reset": "bun scripts/dev-reset.ts",
    "dev:verbose": "bun scripts/dev-verbose.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check --cache --cache-location .prettiercache \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .prettierignore",
    "graph:index": "graphify extract . --out . && graphify cluster-only . --no-label && graphify tree --label umkmcepat",
    "graph:tree": "graphify tree --label umkmcepat",
    "graph:update": "graphify update . && graphify cluster-only . --no-label && graphify tree --label umkmcepat",
    "infra": "docker compose --profile ai --profile langfuse up -d",
    "infra:down": "bun scripts/infra-down.ts",
    "infra:logs": "docker compose logs -f",
    "infra:minimal": "docker compose up -d",
    "infra:ps": "docker compose ps",
    "postinstall": "prisma generate",
    "knip": "knip",
    "langfuse:seed-models": "bun scripts/langfuse-seed-models.ts",
    "lint": "eslint . --max-warnings=0 --cache --cache-location .eslintcache",
    "prepare": "husky",
    "routes:generate": "node scripts/generate-route-tree.mjs",
    "runtime:idle-stop": "bun src/lib/projects/runtime-idle-runner.ts",
    "setup:agent": "bun run graph:index",
    "setup:local": "bun install && docker compose up -d && bun run db:migrate",
    "start": "bun .output/server/index.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:ci": "bun run storybook:build && bun run test:storybook",
    "sweep:project-orphans": "bun scripts/sweep-orphan-project-resources.ts",
    "test": "vitest run --project unit",
    "test:changed": "vitest run --project unit --changed HEAD~1",
    "test:full": "vitest run --project unit",
    "test:storybook": "node scripts/run-storybook-tests.mjs",
    "test:storybook:coverage": "node scripts/run-storybook-tests.mjs --coverage",
    "test:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo",
    "verify": "bun run check:locks && bun run routes:generate && bun run format:check && bun run lint && bun run typecheck && bun run test:full && bun run knip"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "js-yaml": "4.2.0",
    "postcss": "8.5.15",
    "tmp": "0.2.3",
    "uuid": "11.1.1"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.10",
    "@ai-sdk/react": "^4.0.30",
    "@auth/core": "0.34.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@langfuse/otel": "^5.9.1",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.28",
    "ai": "^7.0.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.503.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.42.0",
    "next-themes": "^0.4.6",
    "playwright-core": "1.61.1",
    "prisma": "^6.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@sentry/tanstackstart-react": "10.65.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-generator": "1.167.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.7.1",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "nitro": "^3.0.260610-beta",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": "1.3.9"
  }
}
