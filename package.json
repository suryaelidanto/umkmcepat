{
  "name": "umkmcepat",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "build": "next build",
    "check": "bun run check:locks && bun run format && bun run lint && bun run typecheck && bun run test && bun run knip",
    "check:locks": "bun -e \"import { existsSync } from 'node:fs'; const bad = ['package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'bun.lockb'].filter(existsSync); if (!existsSync('bun.lock') || bad.length) { console.error('Use Bun only. Lockfile: bun.lock. Remove: ' + (bad.join(', ') || 'missing bun.lock')); process.exit(1); }\"",
    "chromatic": "chromatic",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d postgres",
    "dev": "next dev -p 3000",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .prettierignore",
    "graph:index": "graphify extract . --out . && graphify cluster-only . --no-label && graphify tree --label umkmcepat",
    "graph:tree": "graphify tree --label umkmcepat",
    "graph:update": "graphify update . && graphify cluster-only . --no-label && graphify tree --label umkmcepat",
    "infra": "docker compose up -d",
    "infra:ai": "docker compose --profile ai up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps",
    "postinstall": "prisma generate",
    "knip": "knip",
    "lighthouse": "node scripts/run-lighthouse.mjs",
    "lighthouse:auth": "node scripts/run-lighthouse.mjs auth",
    "lighthouse:auth:desktop": "node scripts/run-lighthouse.mjs auth-desktop",
    "lighthouse:auth:mobile": "node scripts/run-lighthouse.mjs auth-mobile",
    "lighthouse:desktop": "node scripts/run-lighthouse.mjs desktop",
    "lighthouse:mobile": "node scripts/run-lighthouse.mjs mobile",
    "lint": "eslint . --max-warnings=0",
    "prepare": "husky",
    "setup:agent": "bun run graph:index",
    "setup:local": "bun install && docker compose up -d && bun run db:migrate",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:ci": "bun run storybook:build && bun run test:storybook",
    "test": "vitest run --project unit",
    "test:storybook": "node scripts/run-storybook-tests.mjs",
    "test:storybook:coverage": "node scripts/run-storybook-tests.mjs --coverage",
    "test:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ai-sdk/react": "^3.0.210",
    "@auth/prisma-adapter": "^2.11.2",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.2.0",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.503.0",
    "monaco-editor": "^0.55.1",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.26",
    "next-themes": "^0.4.6",
    "prisma": "^6.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.15.1",
    "@sentry/nextjs": "^10.58.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.7.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": "1.3.9"
  }
}
