{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/routes/**/*.{ts,tsx}",
    "src/router.tsx",
    "src/client.tsx",
    "src/server.ts",
    "src/start.ts",
    "src/**/*.test.ts",
    "tests/**/*.test.ts",
    ".husky/pre-commit",
    ".husky/commit-msg",
    "scripts/capture-project-thumbnail.cjs"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreBinaries": [
    "graphify",
    "lsof",
    "netstat",
    "ps",
    "powershell.exe",
    "taskkill"
  ],
  "ignoreDependencies": ["agent-browser", "tailwindcss"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/components/ui/**": ["exports"],
    "src/lib/provider-registry.ts": ["exports"],
    "src/lib/storage/index.ts": ["exports"],
    "src/lib/zod-schemas.ts": ["exports", "types"]
  }
}
