{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/{page,layout,route,loading,error,global-error,not-found}.{ts,tsx}",
    "src/**/*.test.ts",
    ".husky/pre-commit",
    ".husky/commit-msg",
    "lighthouserc.mobile.cjs",
    "lighthouserc.desktop.cjs",
    "lighthouserc.auth.mobile.cjs",
    "lighthouserc.auth.desktop.cjs"
  ],
  "project": ["src/**/*.{ts,tsx}", "*.{ts,js,mjs,cjs}"],
  "ignoreBinaries": ["graphify", "netstat"],
  "ignoreDependencies": ["@lhci/cli", "eslint-config-next", "tailwindcss"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/components/ui/**": ["exports"],
    "src/lib/provider-registry.ts": ["exports"],
    "src/lib/storage/index.ts": ["exports"],
    "src/lib/zod-schemas.ts": ["exports", "types"]
  }
}
