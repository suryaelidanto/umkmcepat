datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Make sure this is set in your .env file (e.g., from Neon)
}

generator client {
  provider = "prisma-client-js"
}

model LandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  namaUsaha      String   @db.VarChar(100) // Limit length for better indexing
  kategori       String   @db.VarChar(50)  // Limit length for better indexing
  aiContent      Json? // Store structured AI content (headline, body, cta, colors, etc.)
  harga          String? // TODO: Consider removing if replaced by pricingInfo
  whatsapp       String? // Store formatted WhatsApp number
  images         String[] // Array of image URLs from Cloudinary
  imagePublicIds String[] // Array of Cloudinary public IDs corresponding to images
  userId         String? // Foreign key to User model if claimed
  User           User?    @relation(fields: [userId], references: [id])
  isClaimed      Boolean  @default(false)
  tweaksLeft     Int      @default(5) // Number of AI tweaks remaining
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // === NEW OPTIONAL FIELDS ===
  testimonials Json?    // Changed to Json to store array of objects
  address      String? @db.VarChar(255) // Limit address length
  socialLinks  Json?    // Store social links as JSON

  // === NEW COLOR THEME FIELD ===
  colorTheme   Json?    // Store generated color theme JSON

  @@index([userId])
  @@index([slug])
  @@index([namaUsaha])
  @@index([kategori])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isClaimed])
}

// NextAuth.js (Auth.js v5) Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.VarChar(100)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model User {
  id            String        @id @default(cuid())
  name          String?       @db.VarChar(100)
  email         String?       @unique @db.VarChar(100)
  emailVerified DateTime?
  image         String?       @db.Text
  accounts      Account[]
  sessions      Session[]
  landingPages  LandingPage[] // Relation back to LandingPage

  @@index([email])
  @@index([name])
}

model VerificationToken {
  identifier String   @db.VarChar(100)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}
