datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model LandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  businessName   String   @db.VarChar(100)
  category       String   @db.VarChar(50)
  aiContent      Json?
  price          String?
  whatsappNumber String?
  images         String[]
  imageKeys      String[]
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  isClaimed      Boolean  @default(false)
  tweaksLeft     Int      @default(5)
  testimonials   Json?
  address        String?  @db.VarChar(255)
  socialLinks    Json?
  colorTheme     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([slug])
  @@index([businessName])
  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isClaimed])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model User {
  id              String                  @id @default(cuid())
  name            String?                 @db.VarChar(100)
  email           String?                 @unique @db.VarChar(100)
  emailVerified   DateTime?
  image           String?                 @db.Text
  phone           String?                 @db.VarChar(20)
  verifiedAt      DateTime?
  accounts        Account[]
  sessions        Session[]
  idempotencyKeys ProjectIdempotencyKey[]
  landingPages    LandingPage[]
  projects        Project[]
  editAttempts    ProjectEditAttempt[]
  assets          ProjectAsset[]
  waitlistEntries WaitlistEntry[]
  credits         UserCredit[]
  otpRequests     OtpRequest[]
  payments        Payment[]

  @@index([email])
  @@index([name])
  @@index([verifiedAt])
}

model Project {
  id                        String                  @id @default(cuid())
  title                     String                  @db.VarChar(120)
  prompt                    String                  @db.Text
  model                     String                  @db.VarChar(160)
  status                    String                  @default("draft") @db.VarChar(32)
  siteSchema                Json?
  chatMessages              Json?
  chatSummary               Json?
  memoryFacts               Json?
  lastCompactedMessageCount Int                     @default(0)
  brief                     Json?
  workspaceCard             Json?
  sourceFiles               Json?
  distFiles                 Json?
  buildStatus               String                  @default("not_started") @db.VarChar(32)
  buildLog                  String?                 @db.Text
  builtAt                   DateTime?
  thumbnailRef              String?                 @db.Text
  thumbnailBuildId          String?
  thumbnailUpdatedAt        DateTime?
  activeOperationToken      String?                 @db.VarChar(64)
  activeOperationKind       String?                 @db.VarChar(32)
  activeOperationExpiresAt  DateTime?
  userId                    String
  user                      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots                 ProjectSnapshot[]
  builds                    ProjectBuild[]
  deployments               ProjectDeployment[]
  idempotencyKeys           ProjectIdempotencyKey[]
  runtimeEvents             RuntimeEvent[]
  editAttempts              ProjectEditAttempt[]
  assets                    ProjectAsset[]
  chatTurns                 ProjectChatTurn[]
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  @@index([userId])
  @@index([updatedAt])
  @@index([activeOperationExpiresAt])
  @@index([userId, updatedAt, id])
}

model ProjectChatTurn {
  id            String                @id @db.VarChar(64)
  projectId     String
  userMessageId String                @db.VarChar(64)
  status        ProjectChatTurnStatus
  startedAt     DateTime              @default(now())
  finishedAt    DateTime?
  expiresAt     DateTime
  errorMessage  String?
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([expiresAt])
}

enum ProjectChatTurnStatus {
  running
  succeeded
  failed
  cancelled
}

model ProjectIdempotencyKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(64)
  key       String   @db.VarChar(160)
  createdAt DateTime @default(now())

  @@unique([userId, action, key])
  @@index([projectId])
  @@index([createdAt])
}

/// Owner-scoped uploaded asset (business image / reference / logo) stored under
/// .data/project-assets. The `ref` encodes the on-disk path; cleanup deletes
/// the stored object best-effort alongside the DB row on project delete.
model ProjectAsset {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ref         String   @db.Text
  purpose     String   @db.VarChar(32)
  contentType String   @db.VarChar(64)
  sizeBytes   Int
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([userId])
}

model ProjectEditAttempt {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentSnapshotId String?
  snapshotId       String?
  buildId          String?
  kind             String    @db.VarChar(32)
  status           String    @default("received") @db.VarChar(32)
  instruction      String    @db.Text
  summary          String?   @db.Text
  annotations      Json?
  validationIssues Json?
  advisoryIssues   Json?
  errorMessage     String?   @db.Text
  leaseToken       String?   @db.VarChar(64)
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([userId])
  @@index([status])
  @@index([leaseToken])
}

model ProjectSnapshot {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentSnapshotId String?
  parentSnapshot   ProjectSnapshot?    @relation("ProjectSnapshotParent", fields: [parentSnapshotId], references: [id], onDelete: SetNull)
  childSnapshots   ProjectSnapshot[]   @relation("ProjectSnapshotParent")
  sourceType       String              @default("generated") @db.VarChar(32)
  sourceRef        String?             @db.Text
  files            Json?
  metadata         Json?
  builds           ProjectBuild[]
  deployments      ProjectDeployment[]
  createdAt        DateTime            @default(now())

  @@index([projectId])
  @@index([parentSnapshotId])
  @@index([createdAt])
  @@index([projectId, createdAt])
}

model ProjectBuild {
  id            String              @id @default(cuid())
  projectId     String
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshotId    String
  snapshot      ProjectSnapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  status        String              @db.VarChar(32)
  logRef        String?             @db.Text
  logText       String?             @db.Text
  artifactRef   String?             @db.Text
  imageRef      String?             @db.Text
  startedAt     DateTime?
  finishedAt    DateTime?
  deployments   ProjectDeployment[]
  runtimeEvents RuntimeEvent[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([projectId])
  @@index([snapshotId])
  @@index([status])
  @@index([createdAt])
  @@index([projectId, createdAt])
  @@index([projectId, status, updatedAt])
}

model ProjectDeployment {
  id            String           @id @default(cuid())
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buildId       String?
  build         ProjectBuild?    @relation(fields: [buildId], references: [id], onDelete: SetNull)
  snapshotId    String?
  snapshot      ProjectSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  kind          String           @db.VarChar(32)
  status        String           @db.VarChar(32)
  runtimeNodeId String?
  runtimeNode   RuntimeNode?     @relation(fields: [runtimeNodeId], references: [id], onDelete: SetNull)
  containerName String?          @db.VarChar(160)
  internalUrl   String?          @db.Text
  publicPath    String?          @db.VarChar(255)
  publicUrl     String?          @db.Text
  slug          String?          @db.VarChar(160)
  lastRequestAt DateTime?
  startedAt     DateTime?
  stoppedAt     DateTime?
  runtimeEvents RuntimeEvent[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([projectId])
  @@index([buildId])
  @@index([runtimeNodeId])
  @@index([status])
  @@index([kind])
  @@index([projectId, kind, createdAt])
  @@index([projectId, kind, updatedAt])
  @@index([slug])
}

model RuntimeNode {
  id              String              @id @default(cuid())
  name            String              @unique @db.VarChar(120)
  provider        String              @db.VarChar(64)
  internalUrl     String?             @db.Text
  status          String              @db.VarChar(32)
  maxContainers   Int
  memoryMb        Int?
  cpuCores        Float?
  lastHeartbeatAt DateTime?
  deployments     ProjectDeployment[]
  runtimeEvents   RuntimeEvent[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
}

model RuntimeEvent {
  id            String             @id @default(cuid())
  projectId     String?
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deploymentId  String?
  deployment    ProjectDeployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  buildId       String?
  build         ProjectBuild?      @relation(fields: [buildId], references: [id], onDelete: SetNull)
  runtimeNodeId String?
  runtimeNode   RuntimeNode?       @relation(fields: [runtimeNodeId], references: [id], onDelete: SetNull)
  type          String             @db.VarChar(96)
  message       String?            @db.Text
  metadata      Json?
  createdAt     DateTime           @default(now())

  @@index([projectId])
  @@index([deploymentId])
  @@index([buildId])
  @@index([runtimeNodeId])
  @@index([type])
  @@index([createdAt])
  @@index([projectId, createdAt])
}

model UserCredit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  reason       String   @db.VarChar(64)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

// USD-per-token pricing cache for OpenRouter models, refreshed on a
// background interval (see src/lib/model-pricing.ts). Avoids hitting the
// OpenRouter pricing API on the generation hot path.
model ModelPricing {
  id              String   @id @default(cuid())
  modelId         String   @unique
  promptPrice     Decimal  @db.Decimal(20, 12)
  completionPrice Decimal  @db.Decimal(20, 12)
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
}

model OtpRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(6)
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, phone])
  @@index([expiresAt])
}

model VerificationToken {
  identifier String   @db.VarChar(100)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String   @unique
  amount        Int // Rupiah (cth: 2900)
  energyGranted Int // Jumlah energi (cth: 50000)
  status        String   @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentMethod String? // qris, va, cimb_niaga_va, dll
  paymentNumber String? // QRIS payload / Nomor VA
  type          String   @default("ENERGY_BOOSTER")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Pre-auth pilot waitlist entry. Admin approval gates product access; a
/// signed-up user whose email matches an approved entry is let through, others
/// are redirected to /waitlist. The image (optional) uses the project-asset
/// upload primitive; story is required for approval confidence.
model WaitlistEntry {
  id              String    @id @default(cuid())
  email           String    @unique @db.VarChar(160)
  phone           String?   @db.VarChar(40)
  businessName    String    @db.VarChar(160)
  businessType    String?   @db.VarChar(120)
  story           String    @db.Text
  imageRef        String?   @db.Text
  status          String    @default("pending") @db.VarChar(24)
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewerId      String?   @db.VarChar(160)
  rejectionReason String?   @db.Text
  linkedUserId    String?   @db.VarChar(160)
  user            User?     @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([linkedUserId])
}
