datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model LandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  namaUsaha      String   @db.VarChar(100) 
  kategori       String   @db.VarChar(50)  
  aiContent      Json? 
  harga          String? 
  whatsapp       String? 
  images         String[] 
  imagePublicIds String[] 
  userId         String? 
  User           User?    @relation(fields: [userId], references: [id])
  isClaimed      Boolean  @default(false)
  tweaksLeft     Int      @default(5) 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  
  testimonials Json?    
  address      String? @db.VarChar(255) 
  socialLinks  Json?    

  
  colorTheme   Json?    

  @@index([userId])
  @@index([slug])
  @@index([namaUsaha])
  @@index([kategori])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isClaimed])
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.VarChar(100)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model User {
  id            String        @id @default(cuid())
  name          String?       @db.VarChar(100)
  email         String?       @unique @db.VarChar(100)
  emailVerified DateTime?
  image         String?       @db.Text
  accounts      Account[]
  sessions      Session[]
  landingPages  LandingPage[] 

  @@index([email])
  @@index([name])
}

model VerificationToken {
  identifier String   @db.VarChar(100)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}
