datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model LandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  businessName   String   @db.VarChar(100)
  category       String   @db.VarChar(50)
  aiContent      Json?
  price          String?
  whatsappNumber String?
  images         String[]
  imageKeys      String[]
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  isClaimed      Boolean  @default(false)
  tweaksLeft     Int      @default(5)
  testimonials   Json?
  address        String?  @db.VarChar(255)
  socialLinks    Json?
  colorTheme     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([slug])
  @@index([businessName])
  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isClaimed])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model User {
  id            String        @id @default(cuid())
  name          String?       @db.VarChar(100)
  email         String?       @unique @db.VarChar(100)
  emailVerified DateTime?
  image         String?       @db.Text
  accounts      Account[]
  sessions      Session[]
  landingPages  LandingPage[]
  projects      Project[]

  @@index([email])
  @@index([name])
}

model Project {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(120)
  prompt    String   @db.Text
  model     String   @db.VarChar(160)
  status    String   @default("draft") @db.VarChar(32)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([updatedAt])
}

model VerificationToken {
  identifier String   @db.VarChar(100)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}
